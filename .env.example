# BirdCherry local config — copy to `.env.local` and fill in.
# `.env.local` is gitignored; never commit real keys.

# --- Supabase (real accounts / friends / sightings) ---
SUPABASE_PROJECT_REF=llwrnvljfdkhsptvcbsb
SUPABASE_URL=https://llwrnvljfdkhsptvcbsb.supabase.co
# Dashboard → Project Settings → API → "anon public" (or publishable) key.
# Safe to embed in the client; Row-Level Security protects the data.
SUPABASE_ANON_KEY=
# The database password you set when creating the project (used to run
# migrations). Kept local only.
SUPABASE_DB_PASSWORD=

# --- Free reference-data keys (optional but recommended) ---
# eBird:      https://ebird.org/api/keygen
EBIRD_API_KEY=
# xeno-canto: https://xeno-canto.org  (account settings)
XENO_CANTO_API_KEY=
